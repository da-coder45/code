{
  "manifest_version": 3,
  "name": "SwigShot Offline",
  "version": "1.0",
  "description": "A basketball shooting game that works offline.",
  "action": {
    "default_popup": "game.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "images/*", 
        "media/*", 
        "fonts/*", 
        "data.json", 
        "*.js", 
        "*.wasm", 
        "*.svg",
        "*.woff",
        "icon.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}